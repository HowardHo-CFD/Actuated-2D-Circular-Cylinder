FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];


internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            zeroGradient;
    }
    outlet
    {
        type            zeroGradient;
    }
   "(walls|jet_1|jet_2|jet_3|jet_4|jet_5|neck_walls|walls_sja)"
    {
        type            zeroGradient;
    }
    front
    {
        type            cyclicAMI;
        value           uniform 0;
    }
    back
    {
        type            cyclicAMI;
        value           uniform 0;
    }
}


