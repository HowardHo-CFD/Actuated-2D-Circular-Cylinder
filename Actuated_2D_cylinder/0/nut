FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 2 -1 0 0 0 0 ];

internalField   uniform 1e-12;

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform 0;
    }
    "(outlet|jet_1|jet_2|jet_3|jet_4|jet_5)"
    {
        type            calculated;
        value           uniform 0;
    }
    "(walls|neck_walls|walls_sja)"
    {
        type            fixedValue; //nutLowReWallFunction;
        value           uniform 1e-12;
    }
    "(front|back)"
    {
        type            cyclicAMI;
    }
}


